# ============================================================
# SERVER CONFIG — Copy this to .env.local on the server (38.97.62.139)
# and fill in all values. Never commit .env.local or put passwords here.
# ============================================================

# --- Supabase (required) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- Email (Resend) — get API key from https://resend.com ---
RESEND_API_KEY=re_your_key
EMAIL_FROM=Career Assessment <info@paisoltechnology.com>

# --- Admin (required for /admin) — use a strong secret ---
ADMIN_SECRET=your_secure_admin_password

# --- PDF report branding ---
REPORT_STARTUP_NAME=Paisol

# --- Optional: OpenAI (AI report summary + chat transitions) ---
OPENAI_API_KEY=
