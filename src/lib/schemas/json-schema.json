{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "UserResponsePayload",
  "description": "Payload from frontend for assessment submission",
  "type": "object",
  "required": ["email", "responses"],
  "properties": {
    "user_id": { "type": "string" },
    "email": { "type": "string", "format": "email" },
    "responses": {
      "type": "array",
      "minItems": 54,
      "maxItems": 54,
      "items": {
        "type": "object",
        "required": ["question_id", "selected_options"],
        "properties": {
          "question_id": { "type": "integer", "minimum": 1, "maximum": 54 },
          "selected_options": {
            "type": "array",
            "items": { "type": "string" },
            "maxItems": 2
          },
          "custom_text": { "type": "string" }
        }
      }
    },
    "resume_file_url": { "type": "string" },
    "photo_file_url": { "type": "string" }
  }
}
