/* Home / Landing — PowerPrint™ by biaPathways (brand-aligned) */

.page {
  --home-blue: #01074c;
  --home-cyan: #2dd4ff;
  --home-orange: #fb6322;
  --home-orange-hover: #e55518;
  --home-text: rgba(255, 255, 255, 0.92);
  --home-text-muted: rgba(255, 255, 255, 0.72);
}

.page {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  font-family: var(--font-assessment, 'General Sans', system-ui, sans-serif);
  background:
    radial-gradient(1200px 600px at 50% 120%, rgba(45, 212, 255, 0.25), transparent 60%),
    radial-gradient(900px 500px at 10% 10%, rgba(251, 99, 34, 0.18), transparent 55%),
    linear-gradient(180deg, #070b12 0%, #0a0f1a 60%, #070b12 100%);
  color: var(--home-text);
  overflow: auto;
}

.main {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 2rem 1.5rem;
  position: relative;
  overflow: hidden;
}

.main::before {
  content: '';
  position: absolute;
  inset: 0;
  z-index: 0;
  background-image: url('/theo-bot/assets/Macbook Screen.png');
  background-size: cover;
  background-position: center top;
  background-repeat: no-repeat;
  opacity: 0.22;
  filter: saturate(0.95) contrast(1.05);
  pointer-events: none;
}

.centerWrap {
  position: relative;
  z-index: 1;
  width: 100%;
  max-width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.card {
  max-width: 640px;
  width: 100%;
  text-align: center;
  padding: 2.5rem 2.25rem 2.25rem;
  background: rgba(10, 14, 22, 0.72);
  backdrop-filter: blur(14px);
  border-radius: 22px;
  box-shadow: 0 18px 50px rgba(0, 0, 0, 0.55);
  border: 1px solid rgba(255, 255, 255, 0.14);
  position: relative;
  overflow: hidden;
}

.card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4px;
  background: linear-gradient(90deg, var(--home-orange), var(--home-cyan));
}

.brandRow {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 0.85rem;
  margin-bottom: 1.25rem;
}

.brandAvatar {
  width: 56px;
  height: 56px;
  border-radius: 16px;
  object-fit: cover;
  background: rgba(255, 255, 255, 0.08);
  border: 1px solid rgba(255, 255, 255, 0.14);
}

.brandText {
  text-align: left;
}

.brandName {
  font-size: 1.35rem;
  font-weight: 750;
  letter-spacing: -0.02em;
  line-height: 1.1;
}

.brandTheo {
  color: var(--home-orange);
}

.brandBot {
  color: var(--home-cyan);
}

.brandSub {
  margin-top: 0.1rem;
  font-size: 0.7rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.68);
  font-weight: 600;
}

.title {
  margin: 0 0 1rem;
  font-size: clamp(1.75rem, 4vw, 2.35rem);
  font-weight: 700;
  color: #fff;
  letter-spacing: -0.02em;
  line-height: 1.22;
}

.titleAccent {
  color: var(--home-cyan);
}

.subtitle {
  margin: 0 0 1.75rem;
  font-size: 1.0625rem;
  line-height: 1.65;
  color: var(--home-text-muted);
  max-width: 42ch;
  margin-left: auto;
  margin-right: auto;
}

.quickGrid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 0.75rem;
  margin: 0 auto 1rem;
  max-width: 520px;
}

.quickBtn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.6rem;
  padding: 0.85rem 1rem;
  border-radius: 12px;
  text-decoration: none;
  font-size: 0.95rem;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.92);
  background: rgba(255, 255, 255, 0.08);
  border: 1px solid rgba(255, 255, 255, 0.14);
  transition: transform 0.15s ease, background 0.15s ease, border-color 0.15s ease;
}

.quickBtn:hover {
  transform: translateY(-1px);
  background: rgba(255, 255, 255, 0.12);
  border-color: rgba(255, 255, 255, 0.22);
}

.quickIcon {
  display: inline-flex;
  width: 1.4rem;
  height: 1.4rem;
  align-items: center;
  justify-content: center;
  border-radius: 8px;
  font-size: 1.05rem;
  line-height: 1;
  background: rgba(45, 212, 255, 0.14);
  border: 1px solid rgba(45, 212, 255, 0.22);
}

.inputMock {
  margin: 0.75rem auto 1.25rem;
  max-width: 520px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 0.75rem 0 1rem;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid rgba(255, 255, 255, 0.12);
}

.inputPlaceholder {
  color: rgba(255, 255, 255, 0.62);
  font-size: 0.95rem;
}

.inputSend {
  width: 34px;
  height: 34px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 999px;
  background: rgba(251, 99, 34, 0.9);
  color: #fff;
  font-weight: 700;
}

.cta {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  padding: 0.95rem 2.1rem;
  font-size: 1.0625rem;
  font-weight: 600;
  color: #fff;
  background: linear-gradient(135deg, var(--home-orange) 0%, var(--home-orange-hover) 100%);
  border: none;
  border-radius: 14px;
  text-decoration: none;
  cursor: pointer;
  transition: transform 0.15s ease, box-shadow 0.2s ease;
  box-shadow: 0 4px 16px rgba(251, 99, 34, 0.35);
}

.cta:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(251, 99, 34, 0.4);
}

.cta:active {
  transform: translateY(0);
}

@media (max-width: 640px) {
  .card {
    padding: 2rem 1.25rem 1.75rem;
    border-radius: 20px;
  }

  .title {
    font-size: 1.5rem;
  }

  .quickGrid {
    grid-template-columns: 1fr;
  }

}
