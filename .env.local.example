# Supabase — copy to .env.local and fill in
# Project URL (you provided)
NEXT_PUBLIC_SUPABASE_URL=https://vehfmzyhwzhkxjzchepp.supabase.co

# Publishable / anon key (from Supabase Dashboard → Project Settings → API)
# If your key looks like "sb_publishable_..." paste it here; otherwise use the "anon public" JWT from the dashboard.
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_8DUQBYTdOBFelShaT5MMKg_0UN1xDs3

# Service role key (server-only, for admin and writing sessions) — from same API settings
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Email — Resend (default) or SMTP. Use one.
# Resend: https://resend.com
RESEND_API_KEY=re_your_key
EMAIL_FROM=Career Assessment <onboarding@resend.dev>
# Optional SMTP (e.g. Nodemailer): SMTP_HOST, SMTP_PORT, SMTP_USER, SMTP_PASS — not wired yet; Resend used for now

# Admin dashboard password (any string; keep secret)
ADMIN_SECRET=your_secure_admin_password

# PDF report branding: startup/company name shown at the top so recipients know who the report is from
REPORT_STARTUP_NAME=biaPathways

# Optional: OpenAI API key (https://platform.openai.com/api-keys)
# When set: (1) report PDF summary is AI-generated; (2) chat uses AI-generated transition phrases between answers.
# When missing: placeholder narrative and static transitions (e.g. "Got it.", "Thanks.") are used.
OPENAI_API_KEY=your_openai_api_key
